+
+; ----------------------------------------------------------------------
+; VT100 character-set designation and selection
+;
+; Supported designators:
+;   ESC ( B   Designate US ASCII into G0
+;   ESC ( 0   Designate DEC Special Graphics into G0
+;   ESC ) B   Designate US ASCII into G1
+;   ESC ) 0   Designate DEC Special Graphics into G1
+;   SI        Select G0 into GL
+;   SO        Select G1 into GL
+;
+; The replacement character ROM stores DEC Special Graphics at 00H-1EH.
+; Therefore, while the selected GL set is DEC Special Graphics, received
+; bytes 60H-7EH are translated by subtracting 60H.  All other bytes are
+; passed through unchanged.
+; ----------------------------------------------------------------------
+VT_BEGIN_G0_DESIGNATE:
+        LD      A,STATE_ESC_G0
+        LD      (PARSER_STATE),A
+        RET
+
+VT_BEGIN_G1_DESIGNATE:
+        LD      A,STATE_ESC_G1
+        LD      (PARSER_STATE),A
+        RET
+
+VT_G0_DESIGNATE:
+        LD      B,A
+        XOR     A
+        LD      (PARSER_STATE),A
+        LD      A,B
+        CP      48                       ; '0' = DEC Special Graphics
+        JP      Z,G0_SET_DEC
+        CP      66                       ; 'B' = US ASCII
+        RET     NZ
+        XOR     A
+        LD      (G0_CHARSET),A
+        RET
+G0_SET_DEC:
+        LD      A,CHARSET_DEC
+        LD      (G0_CHARSET),A
+        RET
+
+VT_G1_DESIGNATE:
+        LD      B,A
+        XOR     A
+        LD      (PARSER_STATE),A
+        LD      A,B
+        CP      48                       ; '0' = DEC Special Graphics
+        JP      Z,G1_SET_DEC
+        CP      66                       ; 'B' = US ASCII
+        RET     NZ
+        XOR     A
+        LD      (G1_CHARSET),A
+        RET
+G1_SET_DEC:
+        LD      A,CHARSET_DEC
+        LD      (G1_CHARSET),A
+        RET
+
+SELECT_G0:
+        XOR     A
+        LD      (GL_SELECT),A
+        RET
+
+SELECT_G1:
+        LD      A,1
+        LD      (GL_SELECT),A
+        RET
+
 VT_BEGIN_CSI:
         LD      A,STATE_CSI
         LD      (PARSER_STATE),A
