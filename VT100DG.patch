+
+MAP_GL_CHARACTER:
+        ; Input:  A = received printable character
+        ; Output: A = Bondwell character-ROM code
+        LD      B,A
+        LD      A,(GL_SELECT)
+        OR      A
+        JP      NZ,MAP_GL_USE_G1
+        LD      A,(G0_CHARSET)
+        JP      MAP_GL_TEST_SET
+MAP_GL_USE_G1:
+        LD      A,(G1_CHARSET)
+MAP_GL_TEST_SET:
+        CP      CHARSET_DEC
+        LD      A,B
+        RET     NZ
+        CP      0x060
+        RET     C
+        CP      0x07F
+        RET     NC
+        SUB     0x060                    ; 60H-7EH -> ROM 00H-1EH
+        RET
+
 CURSOR_ADDRESS:
